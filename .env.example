# Modo seguro por defecto
LINKEDIN_CONTENT_AI_ADAPTER=controlled

# Activar solo si se instala el extra `ai-real`
# LINKEDIN_CONTENT_AI_ADAPTER=litellm
# LINKEDIN_CONTENT_AI_PROVIDER=openai
# LINKEDIN_CONTENT_AI_MODEL=gpt-4o-mini

LINKEDIN_CONTENT_AI_TIMEOUT_SECONDS=30
LINKEDIN_CONTENT_AI_MAX_TOKENS=280

# Directorio opcional con perfiles narrativos runtime en JSON:
# <id_perfil>.json
LINKEDIN_CONTENT_PROFILE_DIR=./profiles

# Las credenciales reales del proveedor se configuran fuera del repositorio.
# Ejemplo orientativo, sin valor real:
# OPENAI_API_KEY=
